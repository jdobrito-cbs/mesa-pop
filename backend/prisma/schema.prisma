generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum GameFamily {
  TURN
  PARTY
  PUZZLE
  ARCADE
  ACTION
  ECONOMY
  FLOCKING
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
  CLOSED
}

enum MatchStatus {
  IN_PROGRESS
  FINISHED
  ABANDONED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  /// nome de usuário ÚNICO na plataforma — usado em rankings e jogos
  username     String?   @unique
  name         String
  displayName  String
  phone        String
  passwordHash String
  role         Role      @default(USER)
  avatarUrl    String?
  /// id do avatar procedural ativo (n#/e#/s#)
  avatar       String?
  /// quando o modal "escolha seu avatar" foi mostrado (só uma vez)
  avatarPromptedAt DateTime?
  /// moeda da plataforma (troca por avatares) — admin ganha 100k ao virar admin
  fichas       Int       @default(0)
  isActive     Boolean   @default(true)
  /// conta-sombra do "jogar sem conta" — fora de chat, saves e rankings
  isGuest      Boolean   @default(false)
  bannedUntil  DateTime?
  banReason    String?
  /// proteção contra força bruta: senhas erradas seguidas
  failedLogins Int       @default(0)
  /// bloqueio por tentativas (data futura = bloqueado até o admin liberar)
  lockedUntil  DateTime?
  emailVerifiedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  roomPlayers   RoomPlayer[]
  matchPlayers  MatchPlayer[]
  scores        Score[]
  hostedRooms   Room[]         @relation("RoomHost")
  farm          Farm?
  favorites     FavoriteRoom[]
  termoPlays    TermoPlay[]
  desafioPlays  DesafioPlay[]
  avataresOwned AvatarOwned[]
  pareoBets     PareoBet[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  detail    Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Game {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String
  family      GameFamily
  minPlayers  Int
  maxPlayers  Int
  color       String
  icon        String
  phase       Int
  isEnabled   Boolean    @default(false)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  rooms   Room[]
  matches Match[]
  scores  Score[]
}

model Room {
  id         String     @id @default(cuid())
  code       String     @unique
  gameId     String
  game       Game       @relation(fields: [gameId], references: [id])
  hostId     String
  host       User       @relation("RoomHost", fields: [hostId], references: [id])
  isPrivate  Boolean    @default(false)
  status     RoomStatus @default(WAITING)
  maxPlayers Int
  createdAt  DateTime   @default(now())
  closedAt   DateTime?

  players   RoomPlayer[]
  matches   Match[]
  favorites FavoriteRoom[]

  @@index([gameId, status])
}

/// Palavra do Dia: UMA partida por usuário por dia (a palavra fica no servidor)
model TermoPlay {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String // 'YYYY-MM-DD'
  attempts  Json // [{palpite, feedback}]
  done      Boolean  @default(false)
  won       Boolean  @default(false)
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, date])
  @@index([date, won])
}

/// Desafio Diário — o MESMO puzzle para todos (seed = a data). Uma
/// tentativa por jogo por dia; ranking próprio do dia. O servidor mede
/// a duração (anti-trapaça) a partir de startedAt.
model DesafioPlay {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameSlug  String
  date      String // 'YYYY-MM-DD' — também é a seed do puzzle do dia
  points    Int      @default(0)
  done      Boolean  @default(false)
  startedAt DateTime @default(now())
  elapsedMs Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, gameSlug, date])
  @@index([gameSlug, date, done])
}

/// Avatar ESPECIAL conquistado (troca por fichas na máquina) — posse permanente.
model AvatarOwned {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarId  String
  createdAt DateTime @default(now())

  @@id([userId, avatarId])
}

/// sala pública favoritada por um usuário (fixa no topo do lobby dele)
model FavoriteRoom {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, roomId])
}

model RoomPlayer {
  roomId      String
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?
  isConnected Boolean   @default(true)

  @@id([roomId, userId])
}

model Match {
  id            String      @id @default(cuid())
  gameId        String
  game          Game        @relation(fields: [gameId], references: [id])
  roomId        String?
  room          Room?       @relation(fields: [roomId], references: [id], onDelete: SetNull)
  status        MatchStatus @default(IN_PROGRESS)
  stateSnapshot Json?
  startedAt     DateTime    @default(now())
  endedAt       DateTime?

  players MatchPlayer[]

  @@index([gameId, startedAt])
}

model MatchPlayer {
  matchId   String
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int     @default(0)
  placement Int?
  isWinner  Boolean @default(false)

  @@id([matchId, userId])
  @@index([userId])
}

/// Fazenda Pop — estado econômico persistente por usuário.
/// O crescimento é calculado pelo SERVIDOR a partir de plantedAt (funciona
/// offline: plantou às 14h, colhe às 18h).
model Farm {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coins     Int      @default(50)
  /// canteiros: [{ id, crop: string|null, plantedAt: ISO|null }]
  plots     Json
  /// melhorias: { fertilizer: number }
  upgrades  Json
  /// curral: [{ id, kind, boughtAt: ISO, lastCollectedAt: ISO }]
  animals   Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Configurações da plataforma (chave/valor) — editáveis pelo admin.
model Setting {
  key   String @id
  value String
}

/// Registro PERMANENTE de cada visita de convidado (jogou sem conta).
/// O usuário-convidado é temporário e some ao sair; esta linha fica,
/// para o relatório mensal de quantos jogaram na plataforma.
model GuestVisit {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Aviso global exibido no lobby (criado pelo admin).
model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, createdAt])
}

/// Aposta do Páreo — o LEDGER do jogo: débito no confirmar, crédito na
/// liquidação (valor × odds), tudo pelo servidor. `resultado` garante a
/// idempotência do pagamento (pendente → ganhou/perdeu uma única vez).
/// `seed` + `liquidaEm` tornam a liquidação determinística mesmo se a
/// sala morrer no meio (nenhuma ficha fica presa).
model PareoBet {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId    String
  /// nº do páreo dentro da sala
  numero    Int
  /// seed da corrida (resultado determinístico)
  seed      Int
  /// raia apostada (0..3)
  lane      Int
  valor     Int
  odds      Float
  /// pendente | ganhou | perdeu
  resultado String   @default("pendente")
  payout    Int      @default(0)
  /// quando a corrida termina e a aposta pode ser liquidada
  liquidaEm DateTime
  createdAt DateTime @default(now())

  @@unique([roomId, numero, userId])
  @@index([resultado, liquidaEm])
  @@index([userId, createdAt])
}

/// Entrada de leaderboard — sempre gravada pelo servidor, nunca pelo cliente.
model Score {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  points    Int
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([gameId, points])
  @@index([userId, gameId])
}
