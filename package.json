{
  "name": "mesapop",
  "private": true,
  "version": "0.1.0",
  "description": "Mesa Pop — plataforma web de jogos casuais",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "test": "npm run test -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "installer": "node scripts/build-installer.mjs",
    "wsrta": "node scripts/build-wsrta.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
